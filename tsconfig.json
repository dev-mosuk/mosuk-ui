{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "esnext"],
    "types": ["node", "react"],
    "typeRoots": ["node_modules/@types"],
    "jsx": "react",
    "module": "esnext",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
  },
  "include": ["src/**/*", "src/components/integrations/tbank", "src/providers/tbank", "src/components/display/cards/card/component"],
  "exclude": ["node_modules"]
} 