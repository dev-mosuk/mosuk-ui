{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "esnext"],
    "types": ["node", "react"],
    "typeRoots": ["node_modules/@types"],
    "jsx": "react",
    "module": "esnext",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },  
  "exclude": ["node_modules"]
}
